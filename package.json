{
  "name": "desktopmanagementmcp",
  "version": "2.0.0",
  "description": "Desktop Management MCP Server - JAMF Pro and Microsoft Intune tools",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "start:jamf": "node dist/src/mcp/jamf-server.js",
    "start:intune": "node dist/src/mcp/intune-server.js",
    "test": "tsc -p tsconfig.test.json && node --test dist/test/jamf-api.test.js dist/test/auth.test.js",
    "test:write": "tsc -p tsconfig.test.json && JAMF_TEST_WRITE=1 node --test dist/test/jamf-api.test.js dist/test/auth.test.js",
    "test:unit": "tsc -p tsconfig.test.json && node --test dist/test/auth.test.js"
  },
  "keywords": [],
  "engines": {
    "node": ">=24"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "axios": "^1.13.5",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.2.3",
    "rimraf": "^5.0.0",
    "typescript": "^5.9.3"
  }
}
